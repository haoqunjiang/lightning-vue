{
  "name": "@lightning-vue/compiler",
  "version": "0.0.3",
  "description": "Vue SFC compiler module with a Lightning CSS-backed style compiler",
  "keywords": [
    "compiler-sfc",
    "lightningcss",
    "sfc",
    "vue"
  ],
  "homepage": "https://github.com/haoqunjiang/lightning-vue/tree/main/packages/compiler#readme",
  "bugs": {
    "url": "https://github.com/haoqunjiang/lightning-vue/issues"
  },
  "license": "MIT",
  "author": "Haoqun Jiang <npm@haoqun.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haoqunjiang/lightning-vue.git",
    "directory": "packages/compiler"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.mts",
      "import": "./dist/browser.mjs",
      "require": "./dist/browser.cjs"
    },
    "./debug": {
      "types": "./dist/debug.d.mts",
      "import": "./dist/debug.mjs",
      "require": "./dist/debug.cjs"
    },
    "./debug/nesting": {
      "types": "./dist/debug/nesting.d.mts",
      "import": "./dist/debug/nesting.mjs",
      "require": "./dist/debug/nesting.cjs"
    },
    "./debug/scopedSelector": {
      "types": "./dist/debug/scopedSelector.d.mts",
      "import": "./dist/debug/scopedSelector.mjs",
      "require": "./dist/debug/scopedSelector.cjs"
    },
    "./debug/compileSession": {
      "types": "./dist/debug/compileSession.d.mts",
      "import": "./dist/debug/compileSession.mjs",
      "require": "./dist/debug/compileSession.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "watch": "vp pack --watch",
    "test": "vp test run",
    "bench:sample": "vp test bench bench/compileStyle.compare.bench.ts bench/compileStyle.internal.bench.ts bench/compileStyle.micro.bench.ts bench/scopedSelector.bench.ts",
    "bench:compare:sample": "vp test bench bench/compileStyle.compare.bench.ts",
    "bench:headroom:sample": "node ../../tools/bench-scoped-selector.mjs --bench bench/lightningBaseline.bench.ts --bench bench/compileStyle.internal.bench.ts --runs 1",
    "bench:internal:sample": "vp test bench bench/compileStyle.internal.bench.ts",
    "bench:micro:sample": "vp test bench bench/compileStyle.micro.bench.ts bench/scopedSelector.bench.ts",
    "bench:scoped:sample": "vp test bench bench/scopedSelector.bench.ts",
    "check": "vp check src bench __tests__ package.json README.md ARCHITECTURE.md vite.config.ts tsconfig.json",
    "test:trace": "vp test run __tests__/scopedSelector.trace.spec.ts",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@lightning-vue/utils": "workspace:*",
    "@vue/compiler-core": "catalog:",
    "@vue/compiler-sfc": "catalog:",
    "@vue/shared": "catalog:",
    "hash-sum": "^2.0.0",
    "magic-string": "^0.30.21",
    "merge-source-map": "^1.1.0"
  },
  "devDependencies": {
    "lightningcss": "^1.32.0",
    "sass": "^1.99.0"
  },
  "peerDependencies": {
    "lightningcss": "^1.32.0"
  }
}
