{
  "name": "@lightning-vue/utils",
  "version": "0.0.4",
  "description": "Lightning CSS-compatible selector and CSS source utilities for Vue tooling",
  "keywords": [
    "css",
    "lightningcss",
    "selectors",
    "vue"
  ],
  "homepage": "https://github.com/haoqunjiang/lightning-vue/tree/main/packages/utils#readme",
  "bugs": {
    "url": "https://github.com/haoqunjiang/lightning-vue/issues"
  },
  "license": "MIT",
  "author": "Haoqun Jiang <npm@haoqun.me>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haoqunjiang/lightning-vue.git",
    "directory": "packages/utils"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack src/index.ts --format esm --format cjs --dts",
    "watch": "vp pack src/index.ts --format esm --format cjs --dts --watch",
    "test": "vp test run",
    "check": "vp check src __tests__ package.json README.md ARCHITECTURE.md vite.config.ts tsconfig.json",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "magic-string": "^0.30.21"
  },
  "devDependencies": {
    "lightningcss": "^1.32.0"
  },
  "peerDependencies": {
    "lightningcss": "^1.32.0"
  },
  "peerDependenciesMeta": {
    "lightningcss": {
      "optional": true
    }
  }
}
