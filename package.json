{
  "name": "lightning-vue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "pnpm check && vp run -r test && vp run --filter './apps/*' build",
    "build": "pnpm build:apps",
    "build:packages": "node tools/build-packages.mjs",
    "build:apps": "pnpm build:packages && vp run --filter './apps/*' build",
    "build:pages": "pnpm build:packages && node tools/build-pages.mjs",
    "test": "vp run -r test",
    "bench": "vp run compiler#bench",
    "bench:scoped": "vp run compiler#bench:scoped",
    "bench:scoped:compare": "node tools/bench-scoped-selector.mjs",
    "check": "pnpm build:packages && vp check && vp run --filter './packages/*' --filter './apps/*' check",
    "test:trace:scoped": "vp run compiler#test:trace",
    "sync:tests": "node tools/sync-vue-tests.mjs",
    "dev:playground": "node tools/dev-app.mjs sfc-playground",
    "dev:example": "node tools/dev-app.mjs vite-example",
    "dev:divergence": "node tools/dev-app.mjs divergence-playground",
    "dev:ir": "node tools/dev-app.mjs ir-playground"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0"
}
