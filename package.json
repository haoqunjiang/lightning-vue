{
  "name": "lightning-vue",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ready": "vp check && vp run -r test && vp run -r build",
    "build": "vp run -r build",
    "test": "vp run -r test",
    "bench": "vp run compiler#bench",
    "bench:scoped": "vp run compiler#bench:scoped",
    "bench:scoped:compare": "node tools/bench-scoped-selector.mjs",
    "check": "vp run -r check",
    "test:trace:scoped": "vp run compiler#test:trace",
    "sync:tests": "node tools/sync-vue-tests.mjs",
    "dev:playground": "vp run sfc-playground#dev",
    "dev:example": "vp run vite-example#dev",
    "dev:divergence": "vp run divergence-playground#dev",
    "dev:ir": "vp run ir-playground#dev"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@10.33.0"
}
